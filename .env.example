# =============================================================================
# 사내 회의실 예약 시스템 - 환경변수 템플릿
# =============================================================================
# 이 파일을 .env로 복사한 뒤 실제 값을 채워서 사용하세요.
#   cp .env.example .env
#
# .env 파일은 .gitignore에 등록되어 있어야 합니다.
# =============================================================================

# -----------------------------------------------------------------------------
# Docker Compose - 인프라
# -----------------------------------------------------------------------------
POSTGRES_USER=meetingroom
POSTGRES_PASSWORD=meetingroom_dev_pw
POSTGRES_DB=meetingroom_dev
POSTGRES_PORT=5432

MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
ADMINER_PORT=8081

# -----------------------------------------------------------------------------
# Backend (NestJS) - 애플리케이션
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001

# DB 연결 (Docker Compose 외부에서 접근 시: localhost)
DATABASE_URL="postgresql://meetingroom:meetingroom_dev_pw@localhost:5432/meetingroom_dev?schema=public"

# JWT 시크릿 (운영 환경에서는 절대 이 값을 사용하지 말 것)
JWT_ACCESS_SECRET=change-this-access-secret-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_REFRESH_EXPIRES_IN=14d

# CORS 허용 오리진 (콤마로 구분)
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# 이메일 (로컬: MailHog)
# -----------------------------------------------------------------------------
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@meetingroom.local
MAIL_FROM_NAME="회의실 예약 시스템"

# 이메일 인증 코드 해시 저장 여부
# - false: 평문 저장 (로컬/개발)
# - true: SHA-256 해시 저장 (스테이징/운영)
EMAIL_CODE_HASH_ENABLED=false

# 인증 코드 정책
EMAIL_CODE_LENGTH=6
EMAIL_CODE_TTL_MINUTES=10
EMAIL_CODE_MAX_ATTEMPTS=5
EMAIL_CODE_RESEND_COOLDOWN_SECONDS=60

# -----------------------------------------------------------------------------
# 인증/보안 정책
# -----------------------------------------------------------------------------
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=30
PASSWORD_RESET_TTL_HOURS=1

# 비밀번호 정책 (정규식)
PASSWORD_MIN_LENGTH=8

# argon2 옵션 (memoryCost in KiB)
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# -----------------------------------------------------------------------------
# 비즈니스 정책
# -----------------------------------------------------------------------------
BOOKING_MAX_DURATION_MINUTES=240
BOOKING_TIME_UNIT_MINUTES=15
RECURRENCE_MAX_RANGE_DAYS=365
ROOM_MAX_COUNT=10

# 캘린더 조회 최대 기간
CALENDAR_MAX_RANGE_DAYS=31

# -----------------------------------------------------------------------------
# Rate Limiting (요청수/초)
# -----------------------------------------------------------------------------
RATE_LIMIT_GLOBAL_PER_MINUTE=500
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_SIGNUP_PER_MINUTE=5

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_NAME="회의실 예약"

# 메인 색상 (회사 브랜드 색으로 변경 가능 - PRD UX-002)
NEXT_PUBLIC_PRIMARY_COLOR=#1A73E8

# -----------------------------------------------------------------------------
# 시드 데이터 (개발용 초기 ADMIN 계정)
# -----------------------------------------------------------------------------
SEED_ADMIN_EMAIL=admin@meetingroom.local
SEED_ADMIN_PASSWORD=Admin123!@#
SEED_ADMIN_NAME=관리자

// =============================================================================
// 사내 회의실 예약 시스템 - Prisma Schema
// =============================================================================
// 문서 참조: docs/02-db-design.md
// 작성일: 2026-04-23
// 버전: 1.0
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [btree_gist] // 시간 겹침 EXCLUDE 제약에 필요
}

// =============================================================================
// Enums
// =============================================================================

enum UserRole {
  USER
  ADMIN

  @@map("user_role")
}

enum UserStatus {
  PENDING // 이메일 인증 대기
  ACTIVE // 정상
  LOCKED // 로그인 실패 누적으로 잠금
  DELETED // 소프트 삭제

  @@map("user_status")
}

enum ExceptionRequestStatus {
  PENDING // 검토 대기
  APPROVED // 승인됨 (Booking 생성됨)
  REJECTED // 반려됨
  CANCELLED // 신청자 취소

  @@map("exception_request_status")
}

// =============================================================================
// User & Auth
// =============================================================================

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique @db.VarChar(255)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  name         String     @db.VarChar(50)
  department   String?    @db.VarChar(100)
  employeeNo   String?    @map("employee_no") @db.VarChar(50)
  phone        String?    @db.VarChar(20)
  role         UserRole   @default(USER)
  status       UserStatus @default(PENDING)
  lockedUntil  DateTime?  @map("locked_until") @db.Timestamptz(6)
  lastLoginAt  DateTime?  @map("last_login_at") @db.Timestamptz(6)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  emailVerifications EmailVerification[]
  refreshTokens      RefreshToken[]
  passwordResets     PasswordReset[]
  bookings           Booking[]
  recurrenceRules    RecurrenceRule[]
  exceptionRequests  ExceptionRequest[]   @relation("RequestedByUser")
  reviewedRequests   ExceptionRequest[]   @relation("ReviewedByUser")
  auditLogs          AuditLog[]

  @@index([email], map: "idx_user_email")
  @@index([status], map: "idx_user_status")
  @@map("user")
}

model EmailVerification {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  code         String    @db.VarChar(255) // 평문(로컬) 또는 SHA-256 해시(운영)
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(6)
  attemptCount Int       @default(0) @map("attempt_count")
  verifiedAt   DateTime? @map("verified_at") @db.Timestamptz(6)
  sentAt       DateTime  @default(now()) @map("sent_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_email_verification_user")
  @@map("email_verification")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  userAgent String?   @map("user_agent") @db.VarChar(500)
  ipAddress String?   @map("ip_address") @db.Inet
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash], map: "idx_refresh_token_hash")
  @@index([userId, revokedAt], map: "idx_refresh_token_user_active")
  @@map("refresh_token")
}

model PasswordReset {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset")
}

model LoginAttempt {
  id          String   @id @default(uuid()) @db.Uuid
  email       String   @db.VarChar(255)
  ipAddress   String?  @map("ip_address") @db.Inet
  success     Boolean
  attemptedAt DateTime @default(now()) @map("attempted_at") @db.Timestamptz(6)

  @@index([email, attemptedAt(sort: Desc)], map: "idx_login_attempt_email_recent")
  @@map("login_attempt")
}

// =============================================================================
// Room
// =============================================================================

model Room {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @unique @db.VarChar(100)
  capacity     Int?
  location     String?  @db.VarChar(200)
  description  String?  @db.Text
  isActive     Boolean  @default(true) @map("is_active")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  bookings          Booking[]
  recurrenceRules   RecurrenceRule[]
  exceptionRequests ExceptionRequest[]

  @@index([isActive, displayOrder], map: "idx_room_active_order")
  @@map("room")
}

// =============================================================================
// Booking & Recurrence
// =============================================================================

model Booking {
  id                 String    @id @default(uuid()) @db.Uuid
  roomId             String    @map("room_id") @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  title              String    @db.VarChar(200)
  description        String?   @db.Text
  startAt            DateTime  @map("start_at") @db.Timestamptz(6)
  endAt              DateTime  @map("end_at") @db.Timestamptz(6)
  recurrenceId       String?   @map("recurrence_id") @db.Uuid
  recurrenceIndex    Int?      @map("recurrence_index")
  createdByAdmin     Boolean   @default(false) @map("created_by_admin")
  exceptionRequestId String?   @unique @map("exception_request_id") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz(6)

  room             Room              @relation(fields: [roomId], references: [id], onDelete: Restrict)
  user             User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  recurrence       RecurrenceRule?   @relation(fields: [recurrenceId], references: [id], onDelete: SetNull)
  exceptionRequest ExceptionRequest? @relation(fields: [exceptionRequestId], references: [id], onDelete: SetNull)

  @@index([roomId, startAt, endAt], map: "idx_booking_room_time")
  @@index([userId, startAt], map: "idx_booking_user_time")
  @@index([recurrenceId], map: "idx_booking_recurrence")
  @@map("booking")
}

model RecurrenceRule {
  id              String   @id @default(uuid()) @db.Uuid
  roomId          String   @map("room_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  title           String   @db.VarChar(200)
  description     String?  @db.Text
  rrule           String   @db.Text
  durationMinutes Int      @map("duration_minutes") // 15의 배수, 최대 240
  startAt         DateTime @map("start_at") @db.Timestamptz(6)
  untilAt         DateTime @map("until_at") @db.Timestamptz(6) // 시스템상 1년 제한
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  room       Room                  @relation(fields: [roomId], references: [id], onDelete: Restrict)
  user       User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  bookings   Booking[]
  exceptions RecurrenceException[]

  @@map("recurrence_rule")
}

model RecurrenceException {
  id           String   @id @default(uuid()) @db.Uuid
  recurrenceId String   @map("recurrence_id") @db.Uuid
  excludedDate DateTime @map("excluded_date") @db.Date
  reason       String?  @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  recurrence RecurrenceRule @relation(fields: [recurrenceId], references: [id], onDelete: Cascade)

  @@unique([recurrenceId, excludedDate])
  @@map("recurrence_exception")
}

// =============================================================================
// Exception Request (관리자 예외 신청 워크플로우)
// =============================================================================

model ExceptionRequest {
  id             String                 @id @default(uuid()) @db.Uuid
  userId         String                 @map("user_id") @db.Uuid
  roomId         String                 @map("room_id") @db.Uuid
  startAt        DateTime               @map("start_at") @db.Timestamptz(6)
  endAt          DateTime               @map("end_at") @db.Timestamptz(6)
  title          String                 @db.VarChar(200)
  reason         String                 @db.Text
  status         ExceptionRequestStatus @default(PENDING)
  reviewerId     String?                @map("reviewer_id") @db.Uuid
  reviewComment  String?                @map("review_comment") @db.Text
  reviewedAt     DateTime?              @map("reviewed_at") @db.Timestamptz(6)
  createdAt      DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  user     User      @relation("RequestedByUser", fields: [userId], references: [id], onDelete: Restrict)
  room     Room      @relation(fields: [roomId], references: [id], onDelete: Restrict)
  reviewer User?     @relation("ReviewedByUser", fields: [reviewerId], references: [id], onDelete: SetNull)
  booking  Booking?

  @@index([status, createdAt], map: "idx_exception_request_status")
  @@index([userId, createdAt(sort: Desc)], map: "idx_exception_request_user")
  @@map("exception_request")
}

// =============================================================================
// Audit Log
// =============================================================================

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  action     String   @db.VarChar(100) // 예: BOOKING_CREATED, USER_ROLE_CHANGED
  targetType String   @map("target_type") @db.VarChar(50) // BOOKING, USER, ROOM
  targetId   String?  @map("target_id") @db.Uuid
  payload    Json?    @db.JsonB
  ipAddress  String?  @map("ip_address") @db.Inet
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([targetType, targetId, createdAt(sort: Desc)], map: "idx_audit_log_target")
  @@index([actorId, createdAt(sort: Desc)], map: "idx_audit_log_actor")
  @@map("audit_log")
}
